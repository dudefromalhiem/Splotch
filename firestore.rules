rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    match /products/{productId} {
      allow read: if true;
      allow create, delete: if request.auth != null && request.auth.token.email == 'splotchglobal@gmail.com';
      allow update: if request.auth != null; 
    }
    
    match /portfolio/{itemId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'splotchglobal@gmail.com';
    }

    match /promos/{promoId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'splotchglobal@gmail.com';
    }
    
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.email == 'splotchglobal@gmail.com');
    }
    
    match /userCarts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.token.email == 'splotchglobal@gmail.com';
    }
    
  }
}
