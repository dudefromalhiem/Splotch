rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'splotchglobal@gmail.com';
    }
    
    match /portfolio/{itemId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'splotchglobal@gmail.com';
    }

    match /promos/{promoId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'splotchglobal@gmail.com';
    }
    
    match /orders/{id} {
      allow read, write: if request.auth != null && request.auth.token.email == 'splotchglobal@gmail.com';
    }
    
    match /userCarts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /messages/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.token.email == 'splotchglobal@gmail.com';
    }
    
  }
}
